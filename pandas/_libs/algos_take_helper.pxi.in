# ----------------------------------------------------------------------
# Hand-rolled object take functions with manual refcount control.
# Using raw PyObject** pointers and explicit Py_INCREF / Py_XDECREF
# avoids the overhead of Python-level assignment (which does an implicit
# INCREF on the new value + XDECREF on the old, plus memoryview stride
# arithmetic on every iteration).
# ----------------------------------------------------------------------


@cython.wraparound(False)
@cython.boundscheck(False)
def take_1d_object_object(
        ndarray[object, ndim=1] values,
        const intp_t[:] indexer,
        ndarray[object, ndim=1] out,
        fill_value=np.nan,
        bint allow_fill=True):

    cdef:
        Py_ssize_t i, n, n4
        Py_ssize_t idx0, idx1, idx2, idx3, idx
        object fv
        PyObject **values_ptr
        PyObject **out_ptr
        Py_ssize_t vs0 = values.strides[0] // sizeof(PyObject*)
        Py_ssize_t os0 = out.strides[0] // sizeof(PyObject*)
        PyObject *src
        PyObject *dst

    n = indexer.shape[0]
    n4 = n - (n % 4)

    values_ptr = <PyObject**> values.data
    out_ptr = <PyObject**> out.data
    fv = fill_value

    if allow_fill:
        # 4-way unrolled loop
        for i in range(0, n4, 4):

            # ---- 0 ----
            idx0 = indexer[i]
            if idx0 == -1:
                src = <PyObject*>fv
            else:
                src = values_ptr[idx0 * vs0]

            Py_INCREF(<object>src)
            dst = out_ptr[i * os0]
            Py_XDECREF(dst)
            out_ptr[i * os0] = src

            # ---- 1 ----
            idx1 = indexer[i + 1]
            if idx1 == -1:
                src = <PyObject*>fv
            else:
                src = values_ptr[idx1 * vs0]

            Py_INCREF(<object>src)
            dst = out_ptr[(i + 1) * os0]
            Py_XDECREF(dst)
            out_ptr[(i + 1) * os0] = src

            # ---- 2 ----
            idx2 = indexer[i + 2]
            if idx2 == -1:
                src = <PyObject*>fv
            else:
                src = values_ptr[idx2 * vs0]

            Py_INCREF(<object>src)
            dst = out_ptr[(i + 2) * os0]
            Py_XDECREF(dst)
            out_ptr[(i + 2) * os0] = src

            # ---- 3 ----
            idx3 = indexer[i + 3]
            if idx3 == -1:
                src = <PyObject*>fv
            else:
                src = values_ptr[idx3 * vs0]

            Py_INCREF(<object>src)
            dst = out_ptr[(i + 3) * os0]
            Py_XDECREF(dst)
            out_ptr[(i + 3) * os0] = src

        # tail
        for i in range(n4, n):
            idx = indexer[i]

            if idx == -1:
                src = <PyObject*>fv
            else:
                src = values_ptr[idx * vs0]

            Py_INCREF(<object>src)
            dst = out_ptr[i * os0]
            Py_XDECREF(dst)
            out_ptr[i * os0] = src
    else:
        # No -1 entries possible, skip fill_value checks
        for i in range(0, n4, 4):

            src = values_ptr[indexer[i] * vs0]
            Py_INCREF(<object>src)
