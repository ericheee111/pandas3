                                    ndarray[intp_t, ndim=1] indexer,
                                    {{c_type_out}}[:, :] out,
                                    fill_value={{get_fill_default(c_type_out)}},
                                    bint allow_fill=True):

    cdef:
        Py_ssize_t i, j, k, n, idx
        {{c_type_out}} fv
        {{if c_type_in != "object" and c_type_out != "object"}}
        Py_ssize_t k4
        bint contig
        {{if c_type_in == c_type_out}}
        bint contiguous_indexer
        intp_t start
        {{endif}}
        const {{c_type_in}} *vrow
        const intp_t *ip
        {{c_type_out}} *orow
        intp_t i0, i1, i2, i3
        {{endif}}

    n = len(values)
    k = len(indexer)

    if n == 0 or k == 0:
        return

    fv = fill_value

    {{if c_type_in != "object" and c_type_out != "object"}}
    contig = (
        values.strides[1] == sizeof({{c_type_in}})
        and out.strides[1] == sizeof({{c_type_out}})
        and indexer.strides[0] == sizeof(intp_t)
    )
    k4 = k - (k % 4)
    with nogil:
        if contig:
            ip = &indexer[0]
            {{if c_type_in == c_type_out}}
            # Check whether the indexer represents a contiguous slice
            # (e.g. [5,6,7,…,5+k-1]); if so, a single memcpy per row
            # is far cheaper than element-by-element indexing.
            contiguous_indexer = False
            start = ip[0]
            if start != -1:
                contiguous_indexer = True
                for j in range(1, k):
                    if ip[j] != start + j:
                        contiguous_indexer = False
                        break

            if contiguous_indexer:
                if allow_fill:
                    for i in range(n):
                        orow = &out[i, 0]
                        vrow = &values[i, 0]
                        memcpy(orow, vrow + start,
                               <size_t>(sizeof({{c_type_out}}) * k))
                else:
                    for i in range(n):
                        orow = &out[i, 0]
                        vrow = &values[i, 0]
                        memcpy(orow, vrow + start,
                               <size_t>(sizeof({{c_type_out}}) * k))
            elif allow_fill:
            {{else}}
            if allow_fill:
            {{endif}}
                for i in range(n):
                    vrow = &values[i, 0]
                    orow = &out[i, 0]
                    for j in range(0, k4, 4):
                        i0 = ip[j]
                        i1 = ip[j + 1]
                        i2 = ip[j + 2]
                        i3 = ip[j + 3]
                        orow[j]     = fv if i0 == -1 else vrow[i0]
                        orow[j + 1] = fv if i1 == -1 else vrow[i1]
                        orow[j + 2] = fv if i2 == -1 else vrow[i2]
                        orow[j + 3] = fv if i3 == -1 else vrow[i3]
                    for j in range(k4, k):
                        idx = ip[j]
                        orow[j] = fv if idx == -1 else vrow[idx]
            else:
                for i in range(n):
                    vrow = &values[i, 0]
                    orow = &out[i, 0]
                    for j in range(0, k4, 4):
                        i0 = ip[j]
                        i1 = ip[j + 1]
                        i2 = ip[j + 2]
                        i3 = ip[j + 3]
                        orow[j]     = vrow[i0]
                        orow[j + 1] = vrow[i1]
                        orow[j + 2] = vrow[i2]
                        orow[j + 3] = vrow[i3]
                    for j in range(k4, k):
                        orow[j] = vrow[ip[j]]
        elif allow_fill:
            for i in range(n):
                j = 0
                while j <= k - 4:
                    i0 = indexer[j]
                    i1 = indexer[j + 1]
                    i2 = indexer[j + 2]
                    i3 = indexer[j + 3]

                    out[i, j]     = fv if i0 == -1 else values[i, i0]
                    out[i, j + 1] = fv if i1 == -1 else values[i, i1]
                    out[i, j + 2] = fv if i2 == -1 else values[i, i2]
                    out[i, j + 3] = fv if i3 == -1 else values[i, i3]

                    j += 4

                while j < k:
                    idx = indexer[j]
                    out[i, j] = fv if idx == -1 else values[i, idx]
                    j += 1
        else:
            for i in range(n):
                j = 0
                while j <= k - 4:
                    i0 = indexer[j]
                    i1 = indexer[j + 1]
                    i2 = indexer[j + 2]
                    i3 = indexer[j + 3]

                    out[i, j]     = values[i, i0]
                    out[i, j + 1] = values[i, i1]
                    out[i, j + 2] = values[i, i2]
                    out[i, j + 3] = values[i, i3]

                    j += 4

                while j < k:
                    out[i, j] = values[i, indexer[j]]
                    j += 1

    {{else}}
    if allow_fill:
        for i in range(n):
            for j in range(k):
                idx = indexer[j]
                if idx == -1:
                    out[i, j] = fv
                else:
                    {{if c_type_in == "uint8_t" and c_type_out == "object"}}
                    out[i, j] = True if values[i, idx] > 0 else False
