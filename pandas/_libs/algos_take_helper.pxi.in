                    idx = indexer[i]
                    if idx == -1:
                        for j in range(k):
                            out[i, j] = fv
                    else:
                        for j in range(k):
                            out[i, j] = values[idx, j]
            else:
                for i in range(n):
                    for j in range(k):
                        out[i, j] = values[indexer[i], j]
    {{else}}

    if allow_fill:
        for i in range(n):
            idx = indexer[i]
